---
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="Page Not Found - NotarIA"
    description="The page you're looking for doesn't exist. Return to NotarIA homepage."
>
    <section class="min-h-[80vh] flex items-center justify-center px-6">
        <div class="text-center">
            <h1 class="text-6xl md:text-8xl font-bold text-[#92600a] mb-4">404</h1>
            <h2 class="text-2xl font-semibold text-gray-900 mb-4">Page not found</h2>
            <p class="text-gray-600 mb-8 max-w-md mx-auto">
                Sorry, the page you're looking for doesn't exist or has been moved.
            </p>
            <a
                href="/"
                class="inline-flex items-center gap-2 bg-[#92600a] text-white px-6 py-3 rounded-full font-medium hover:bg-[#b07a1a] transition-colors"
            >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to Home
            </a>
        </div>
    </section>
</Layout>
