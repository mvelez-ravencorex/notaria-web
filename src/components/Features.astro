---
const features = [
  {
    title: "Grabación Inteligente",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>`,
    items: [
      "Grabación con un solo toque",
      "5 idiomas: Español, Inglés, Portugués, Francés, Alemán",
      "Transcripción en vivo",
      "Traducción en tiempo real (iOS 18+)"
    ],
    color: "bg-blue-50 text-blue-600"
  },
  {
    title: "Inteligencia Artificial",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    items: [
      "Resúmenes automáticos concisos",
      "Action items con responsables",
      "Detección de palabras clave",
      "Chat con tu reunión (RAG)"
    ],
    color: "bg-purple-50 text-purple-600"
  },
  {
    title: "Identificación de Hablantes",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
    items: [
      "Detección automática de participantes",
      "Nombres personalizables",
      "Colores distintivos",
      "Estadísticas de participación"
    ],
    color: "bg-emerald-50 text-emerald-600"
  },
  {
    title: "Organización",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>`,
    items: [
      "Carpetas personalizables",
      "Búsqueda global inteligente",
      "Filtrado por fecha y estado",
      "Etiquetas personalizadas"
    ],
    color: "bg-orange-50 text-orange-600"
  },
  {
    title: "Exportación Profesional",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>`,
    items: [
      "PDF con formato profesional",
      "Compartir resumen y transcripción",
      "Descarga de audio (Backup)",
      "Integración con calendario"
    ],
    color: "bg-pink-50 text-pink-600"
  },
  {
    title: "Privacidad y Seguridad",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>`,
    items: [
      "Procesamiento on-device (Apple Speech)",
      "Datos encriptados",
      "Autenticación segura (Google/Apple)",
      "Verificación App Attest"
    ],
    color: "bg-gray-100 text-gray-700"
  }
];
---

<section id="features" class="py-24 bg-gray-50">
  <div class="container mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Todo lo que necesitas para reuniones más productivas</h2>
      <p class="text-xl text-gray-600">NotarIA combina una grabadora potente con inteligencia artificial avanzada para que nunca pierdas un detalle importante.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="bg-white rounded-3xl p-8 shadow-sm hover:shadow-md transition-shadow border border-gray-100 feature-card group">
          <div class={`w-14 h-14 rounded-2xl flex items-center justify-center mb-6 ${feature.color} group-hover:scale-110 transition-transform duration-300`}>
            <Fragment set:html={feature.icon} />
          </div>
          
          <h3 class="text-xl font-bold text-gray-900 mb-4">{feature.title}</h3>
          
          <ul class="space-y-3">
            {feature.items.map((item) => (
              <li class="flex items-start text-gray-600 text-sm">
                <svg class="w-5 h-5 text-emerald-500 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
