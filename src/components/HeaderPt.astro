---
import logoDark from '../assets/images/notaria-dark.png';

const navLinks = [
  { href: '#features', label: 'Funcionalidades' },
  { href: '#how-it-works', label: 'Como funciona' },
  { href: '#pricing', label: 'Preços' },
];
---

<header class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-[95%] max-w-5xl" id="main-header">
  <nav id="main-nav" class="flex items-center justify-between h-14 px-6 rounded-full shadow-lg transition-all duration-300 nav-light">
      <!-- Logo -->
      <a href="/pt" class="flex items-center gap-2 group">
        <img src={logoDark.src} alt="NotarIA Logo" class="h-8 w-8 rounded-xl" />
        <span id="logo-text" class="text-lg font-bold tracking-tight transition-colors duration-300">NotarIA</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8" id="nav-links">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link text-sm font-medium transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Language + CTA -->
      <div class="hidden md:flex items-center gap-3">
        <!-- Language Selector Dropdown -->
        <div class="relative" id="lang-dropdown">
          <button
            class="lang-flag flex items-center gap-1.5 px-3 py-1.5 rounded-full transition-all text-sm font-medium cursor-pointer"
            id="lang-toggle"
            aria-label="Alterar idioma"
            aria-expanded="false"
          >
            <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36">
              <rect width="36" height="36" fill="#009739"/>
              <path d="M1.5 18L18 4.5L34.5 18L18 31.5Z" fill="#FEDD00"/>
              <circle cx="18" cy="18" r="7" fill="#012169"/>
              <path d="M10 18.5Q14 16 18 17Q22 18 26 16.5" stroke="white" stroke-width="1" fill="none"/>
            </svg>
            <span class="lang-label">PT</span>
            <svg class="w-3 h-3 lang-label transition-transform duration-200" id="lang-chevron" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 4.5L6 7.5L9 4.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        <!-- CTA Button -->
        <a href="#" id="nav-cta" class="text-sm font-medium px-5 py-2.5 rounded-full transition-all flex items-center gap-2">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Ir para App Store
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        class="md:hidden p-2 transition-colors"
        id="mobile-menu-btn"
        aria-label="Menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
  </nav>

  <!-- Language dropdown (outside nav for independent backdrop-filter) -->
  <div class="hidden absolute rounded-xl shadow-xl overflow-hidden min-w-[160px] z-50 lang-dropdown-panel" id="lang-menu">
    <a href="/pt" class="lang-dropdown-link lang-dropdown-active flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium transition-colors">
      <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36">
        <rect width="36" height="36" fill="#009739"/>
        <path d="M1.5 18L18 4.5L34.5 18L18 31.5Z" fill="#FEDD00"/>
        <circle cx="18" cy="18" r="7" fill="#012169"/>
        <path d="M10 18.5Q14 16 18 17Q22 18 26 16.5" stroke="white" stroke-width="1" fill="none"/>
      </svg>
      Português
    </a>
    <a href="/" class="lang-dropdown-link flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium transition-colors">
      <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
        <rect width="36" height="36" fill="#B22234"/>
        <rect y="2.77" width="36" height="2.77" fill="white"/>
        <rect y="8.31" width="36" height="2.77" fill="white"/>
        <rect y="13.85" width="36" height="2.77" fill="white"/>
        <rect y="19.38" width="36" height="2.77" fill="white"/>
        <rect y="24.92" width="36" height="2.77" fill="white"/>
        <rect y="30.46" width="36" height="2.77" fill="white"/>
        <rect width="14.4" height="19.38" fill="#3C3B6E"/>
      </svg>
      English
    </a>
    <a href="/es" class="lang-dropdown-link flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium transition-colors">
      <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
        <rect width="36" height="12" fill="#74ACDF"/>
        <rect y="12" width="36" height="12" fill="white"/>
        <rect y="24" width="36" height="12" fill="#74ACDF"/>
        <circle cx="18" cy="18" r="3.5" fill="#F6B40E" stroke="#85340A" stroke-width="0.5"/>
      </svg>
      Español
    </a>
    <a href="/fr" class="lang-dropdown-link flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium transition-colors">
      <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36">
        <rect width="12" height="36" fill="#002395"/>
        <rect x="12" width="12" height="36" fill="white"/>
        <rect x="24" width="12" height="36" fill="#ED2939"/>
      </svg>
      Français
    </a>
    <a href="/de" class="lang-dropdown-link flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium transition-colors">
      <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36">
        <rect width="36" height="12" fill="#000000"/>
        <rect y="12" width="36" height="12" fill="#DD0000"/>
        <rect y="24" width="36" height="12" fill="#FFCC00"/>
      </svg>
      Deutsch
    </a>
    <a href="/it" class="lang-dropdown-link flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium transition-colors">
      <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36">
        <rect width="12" height="36" fill="#009246"/>
        <rect x="12" width="12" height="36" fill="white"/>
        <rect x="24" width="12" height="36" fill="#CE2B37"/>
      </svg>
      Italiano
    </a>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden hidden mt-2 bg-white border border-gray-200 rounded-2xl shadow-lg" id="mobile-menu">
    <div class="flex flex-col p-4 space-y-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-base font-medium text-gray-600 hover:text-[#92600a] transition-colors"
        >
          {link.label}
        </a>
      ))}
      <hr class="border-gray-100" />
      <!-- Language options in mobile -->
      <div class="flex flex-col gap-2">
        <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Idioma</span>
        <a href="/pt" class="flex items-center gap-2.5 px-3 py-2 rounded-lg bg-amber-50 text-gray-900 font-medium transition-colors">
          <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36">
            <rect width="36" height="36" fill="#009739"/>
            <path d="M1.5 18L18 4.5L34.5 18L18 31.5Z" fill="#FEDD00"/>
            <circle cx="18" cy="18" r="7" fill="#012169"/>
            <path d="M10 18.5Q14 16 18 17Q22 18 26 16.5" stroke="white" stroke-width="1" fill="none"/>
          </svg>
          <span class="text-sm">Português</span>
        </a>
        <a href="/" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-50 font-medium transition-colors">
          <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
            <rect width="36" height="36" fill="#B22234"/>
            <rect y="2.77" width="36" height="2.77" fill="white"/>
            <rect y="8.31" width="36" height="2.77" fill="white"/>
            <rect y="13.85" width="36" height="2.77" fill="white"/>
            <rect y="19.38" width="36" height="2.77" fill="white"/>
            <rect y="24.92" width="36" height="2.77" fill="white"/>
            <rect y="30.46" width="36" height="2.77" fill="white"/>
            <rect width="14.4" height="19.38" fill="#3C3B6E"/>
          </svg>
          <span class="text-sm">English</span>
        </a>
        <a href="/es" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-50 font-medium transition-colors">
          <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
            <rect width="36" height="12" fill="#74ACDF"/>
            <rect y="12" width="36" height="12" fill="white"/>
            <rect y="24" width="36" height="12" fill="#74ACDF"/>
            <circle cx="18" cy="18" r="3.5" fill="#F6B40E" stroke="#85340A" stroke-width="0.5"/>
          </svg>
          <span class="text-sm">Español</span>
        </a>
        <a href="/fr" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-50 font-medium transition-colors">
          <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36">
            <rect width="12" height="36" fill="#002395"/>
            <rect x="12" width="12" height="36" fill="white"/>
            <rect x="24" width="12" height="36" fill="#ED2939"/>
          </svg>
          <span class="text-sm">Français</span>
        </a>
        <a href="/de" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-50 font-medium transition-colors">
          <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36">
            <rect width="36" height="12" fill="#000000"/>
            <rect y="12" width="36" height="12" fill="#DD0000"/>
            <rect y="24" width="36" height="12" fill="#FFCC00"/>
          </svg>
          <span class="text-sm">Deutsch</span>
        </a>
        <a href="/it" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-50 font-medium transition-colors">
          <svg class="w-5 h-5 rounded-sm overflow-hidden shrink-0" viewBox="0 0 36 36">
            <rect width="12" height="36" fill="#009246"/>
            <rect x="12" width="12" height="36" fill="white"/>
            <rect x="24" width="12" height="36" fill="#CE2B37"/>
          </svg>
          <span class="text-sm">Italiano</span>
        </a>
      </div>
      <hr class="border-gray-100" />
      <a href="#" class="bg-[#111827] text-white w-full text-center py-3 rounded-full font-medium hover:bg-[#1f2937] flex items-center justify-center gap-2">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        Ir para App Store
      </a>
    </div>
  </div>
</header>

<style>
  /* Dark mode - for dark backgrounds */
  .nav-dark {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
  }

  .nav-dark #logo-text {
    color: white;
  }

  .nav-dark .nav-link {
    color: rgba(255, 255, 255, 0.8);
  }

  .nav-dark .nav-link:hover {
    color: white;
  }

  .nav-dark #nav-cta {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
  }

  .nav-dark #nav-cta:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .nav-dark #mobile-menu-btn {
    color: rgba(255, 255, 255, 0.8);
  }

  .nav-dark #mobile-menu-btn:hover {
    color: white;
  }

  .nav-dark .lang-flag {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav-dark .lang-flag:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .nav-dark .lang-label {
    color: rgba(255, 255, 255, 0.8);
  }

  .nav-dark ~ .lang-dropdown-panel {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
  }

  .nav-dark ~ .lang-dropdown-panel .lang-dropdown-link {
    color: rgba(255, 255, 255, 0.8);
  }

  .nav-dark ~ .lang-dropdown-panel .lang-dropdown-link:hover {
    color: white;
    background: rgba(255, 255, 255, 0.1);
  }

  .nav-dark ~ .lang-dropdown-panel .lang-dropdown-active {
    background: rgba(255, 255, 255, 0.08);
  }

  /* Light mode - for light backgrounds */
  .nav-light {
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(32px) saturate(180%);
    -webkit-backdrop-filter: blur(32px) saturate(180%);
  }

  .nav-light #logo-text {
    color: #92600a;
  }

  .nav-light .nav-link {
    color: #92600a;
  }

  .nav-light .nav-link:hover {
    color: #b07a1a;
  }

  .nav-light #nav-cta {
    background: #111827;
    color: white;
  }

  .nav-light #nav-cta:hover {
    background: #1f2937;
  }

  .nav-light #mobile-menu-btn {
    color: #92600a;
  }

  .nav-light #mobile-menu-btn:hover {
    color: #b07a1a;
  }

  .nav-light .lang-flag {
    background: rgba(146, 96, 10, 0.08);
    border: 1px solid rgba(146, 96, 10, 0.15);
  }

  .nav-light .lang-flag:hover {
    background: rgba(146, 96, 10, 0.15);
  }

  .nav-light .lang-label {
    color: #92600a;
  }

  .nav-light ~ .lang-dropdown-panel .lang-dropdown-link {
    color: #92600a;
  }

  .nav-light ~ .lang-dropdown-panel .lang-dropdown-link:hover {
    color: #b07a1a;
    background: rgba(146, 96, 10, 0.08);
  }

  .nav-light ~ .lang-dropdown-panel .lang-dropdown-active {
    background: rgba(146, 96, 10, 0.06);
  }

  /* Language dropdown glass — matches nav-light */
  .lang-dropdown-panel {
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(32px) saturate(180%);
    -webkit-backdrop-filter: blur(32px) saturate(180%);
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const nav = document.getElementById('main-nav');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });

  // Language dropdown
  const langToggle = document.getElementById('lang-toggle');
  const langMenu = document.getElementById('lang-menu');
  const langChevron = document.getElementById('lang-chevron');
  const mainHeader = document.getElementById('main-header');

  function positionLangMenu() {
    if (!langToggle || !langMenu || !mainHeader) return;
    const toggleRect = langToggle.getBoundingClientRect();
    const headerRect = mainHeader.getBoundingClientRect();
    langMenu.style.top = (toggleRect.bottom - headerRect.top + 8) + 'px';
    langMenu.style.right = (headerRect.right - toggleRect.right) + 'px';
  }

  langToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !langMenu?.classList.contains('hidden');
    if (isOpen) {
      langMenu?.classList.add('hidden');
      langChevron?.style.setProperty('transform', 'rotate(0deg)');
      langToggle?.setAttribute('aria-expanded', 'false');
    } else {
      positionLangMenu();
      langMenu?.classList.remove('hidden');
      langChevron?.style.setProperty('transform', 'rotate(180deg)');
      langToggle?.setAttribute('aria-expanded', 'true');
    }
  });

  // Close dropdown on outside click
  document.addEventListener('click', () => {
    langMenu?.classList.add('hidden');
    langChevron?.style.setProperty('transform', 'rotate(0deg)');
    langToggle?.setAttribute('aria-expanded', 'false');
  });

  // Scroll detection for nav style change - check if over dark sections
  function updateNavStyle() {
    const navRect = nav?.getBoundingClientRect();
    if (!navRect) return;

    const navCenter = navRect.top + navRect.height / 2;

    // Get all dark sections (sections with dark backgrounds)
    const darkSections = document.querySelectorAll('section[class*="bg-[#0a0a0f]"], section[class*="bg-black"], #how-it-works');

    let isOverDark = false;

    // Check if nav is over any dark section
    darkSections.forEach(section => {
      const rect = section.getBoundingClientRect();
      if (navCenter >= rect.top && navCenter <= rect.bottom) {
        isOverDark = true;
      }
    });

    if (isOverDark) {
      nav?.classList.remove('nav-light');
      nav?.classList.add('nav-dark');
    } else {
      nav?.classList.remove('nav-dark');
      nav?.classList.add('nav-light');
    }
  }

  window.addEventListener('scroll', updateNavStyle);
  updateNavStyle(); // Initial check
</script>
