---
import screenshotMain from '../assets/images/screenshot-main.png';
import screenshotLeft from '../assets/images/screenshot-left.png';
import screenshotRight from '../assets/images/screenshot-right.png';
---

<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-white">
  <!-- Background Elements -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[1000px] bg-gradient-to-b from-gray-50 to-transparent"></div>
    <!-- Decorativ circles -->
    <div class="absolute top-20 left-10 w-72 h-72 bg-emerald-400/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-blue-400/10 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      
      <!-- Content -->
      <div class="lg:w-1/2 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-50 border border-emerald-100 text-emerald-600 text-xs font-semibold uppercase tracking-wide mb-8">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          Tu asistente de reuniones con IA
        </div>

        <h1 class="text-5xl lg:text-7xl font-bold text-gray-900 leading-[1.1] mb-6 tracking-tight">
          Nunca más pierdas un
          <span class="transparent bg-clip-text bg-gradient-to-r from-emerald-500 to-teal-600">detalle.</span>
        </h1>

        <p class="text-xl text-gray-500 mb-10 leading-relaxed max-w-lg mx-auto lg:mx-0">
          NotarIA graba, transcribe y resume automáticamente tus reuniones. Concéntrate en la conversación, nosotros tomamos las notas.
        </p>

        <div class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
          <a href="#download" class="w-full sm:w-auto px-8 py-4 bg-gray-900 hover:bg-black text-white rounded-2xl font-semibold transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 flex items-center justify-center gap-2">
            <svg viewBox="0 0 24 24" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            App Store
          </a>
          <a href="#how-it-works" class="w-full sm:w-auto px-8 py-4 bg-white border border-gray-200 hover:border-emerald-500 text-gray-700 hover:text-emerald-600 rounded-2xl font-semibold transition-all flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 0 1 0 .656l-5.603 3.113a.375.375 0 0 1-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112Z" />
            </svg>
            Ver Demo
          </a>
        </div>
        
        <div class="mt-8 flex items-center justify-center lg:justify-start gap-4 text-sm text-gray-400">
           <div class="flex -space-x-2">
              <div class="w-8 h-8 rounded-full bg-gray-200 border-2 border-white"></div>
              <div class="w-8 h-8 rounded-full bg-gray-300 border-2 border-white"></div>
              <div class="w-8 h-8 rounded-full bg-gray-400 border-2 border-white"></div>
           </div>
           <p>Usado por +10,000 profesionales</p>
        </div>
      </div>

      <!-- Hero Image / Mockups -->
      <div class="lg:w-1/2 relative">
          <div class="relative w-full max-w-[300px] mx-auto lg:max-w-[350px]">
             <!-- Main Phone -->
             <div class="relative z-20 rounded-[40px] border-[8px] border-gray-900 overflow-hidden shadow-2xl bg-gray-900 phone-mockup-animation">
                <!-- Dynamic Island -->
                 <div class="absolute top-0 left-1/2 -translate-x-1/2 w-28 h-7 bg-black rounded-b-2xl z-30"></div>
                 <img src={screenshotMain.src} alt="NotarIA App Screen" class="w-full h-auto aspect-[9/19.5] object-cover" />
             </div>

             <!-- Floating Elements (Glassmorphism) -->
            <div class="absolute top-20 -left-12 lg:-left-24 z-30 bg-white/80 backdrop-blur-xl p-4 rounded-2xl shadow-xl border border-white/50 animate-float-slow hidden md:block">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 font-medium">Resumen IA</p>
                        <p class="text-sm font-bold text-gray-900">3 Action Items</p>
                    </div>
                </div>
            </div>

            <div class="absolute bottom-40 -right-12 lg:-right-16 z-10 bg-white/80 backdrop-blur-xl p-4 rounded-2xl shadow-xl border border-white/50 animate-float-delayed hidden md:block">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
                         <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 font-medium">Grabando</p>
                        <p class="text-sm font-bold text-gray-900">00:42:15</p>
                    </div>
                </div>
            </div>
          </div>
      </div>

    </div>
  </div>
</section>

<style>
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}
.animate-float-slow {
  animation: float 6s ease-in-out infinite;
}
.animate-float-delayed {
  animation: float 5s ease-in-out 1s infinite;
}
</style>
